
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAuthor(doc) {
      return request.auth.uid == doc.userId;
    }

    function isOwner() {
      return request.auth.uid == resource.data.ownerId;
    }
    
    function isProfileOwner(profileId) {
      return request.auth.uid == profileId;
    }

    match /users/{userId} {
      // Allow user to write to their own document
      allow write: if isSignedIn() && request.auth.uid == userId;
      // Allow user to read their own document
      allow get: if isSignedIn() && request.auth.uid == userId;
      // Allow any signed-in user to list (search) the collection for email search
      allow list: if isSignedIn();
    }
    
    match /users/{userId}/bookmarks/{postId} {
        allow read, write, delete: if isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/saved_studios/{studioId} {
        allow read, write, delete: if isSignedIn() && request.auth.uid == userId;
    }

    match /user_profiles/{userProfileId} {
      allow read: if isSignedIn();
      allow write: if isProfileOwner(userProfileId);
    }

    match /user_profiles/{userProfileId}/portfolio_items/{itemId} {
      allow read: if isSignedIn();
      allow write: if isProfileOwner(userProfileId);
    }

    match /user_profiles/{userProfileId}/statuses/{statusId} {
        allow read: if isSignedIn();
        allow create, update: if isProfileOwner(userProfileId);
    }
    
    match /{path=**}/statuses/{statusId} {
      allow read: if isSignedIn();
    }

    match /follows/{followId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.followerId && followId == request.resource.data.followerId + '_' + request.resource.data.followingId;
      allow delete: if isSignedIn() && request.auth.uid == followId.split('_')[0];
    }
    
    match /user_favorites/{userId}/profiles/{profileId} {
        allow read, write, delete: if isSignedIn() && request.auth.uid == userId;
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isAuthor(request.resource.data);
      allow update: if isSignedIn() && (isAuthor(resource.data) || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'comments', 'shares'])));
      allow delete: if isAuthor(resource.data);
    }
    
    match /posts/{postId}/likes/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

       match /posts/{postId}/comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      // Simplified to prevent timeout. Only comment author can delete.
      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    match /shorts/{shortId} {
      allow read: if isSignedIn();
      allow write: if isAuthor(request.resource.data);
    }

    match /studio_profiles/{studioProfileId} {
      allow read: if isSignedIn();
      allow create: if isProfileOwner(request.resource.data.userProfileId);
      allow update: if isSignedIn() && (isProfileOwner(resource.data.userProfileId) || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'comments', 'shares'])));
    }
    
    match /studio_profiles/{studioProfileId}/likes/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }
    
    match /studio_profiles/{studioProfileId}/comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      // Simplified to prevent timeout. Only comment author can delete.
      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow create: if isOwner();
      allow update, delete: if isOwner();
    }

    match /studio_profiles/{studioProfileId}/bookings/{bookingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
    }

    match /conversations/{conversationId} {
      allow get, update: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participantIds;
    }

    match /conversations/{conversationId}/messages/{messageId} {
      function isParticipant() {
        return request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
      allow read, create: if isSignedIn() && isParticipant();
      allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid && isParticipant();
    }
  }
}
